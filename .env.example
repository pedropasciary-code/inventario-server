# Banco usado pela API FastAPI.
DATABASE_URL=postgresql://usuario:senha@localhost:5432/inventario

# Token compartilhado com o agent no header X-Agent-Token.
AGENT_TOKEN=substitua_por_um_token_longo_e_aleatorio

# Chave usada para assinar a sessao web.
SECRET_KEY=substitua_por_uma_chave_longa_e_aleatoria

# Use true somente quando a aplicacao estiver servida por HTTPS.
SESSION_COOKIE_SECURE=false
