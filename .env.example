# Banco usado pela API FastAPI.
DATABASE_URL=postgresql://usuario:senha@localhost:5432/inventario

# Token compartilhado com o agent no header X-Agent-Token.
AGENT_TOKEN=substitua_por_um_token_longo_e_aleatorio

# Chave usada para assinar a sessao web.
SECRET_KEY=substitua_por_uma_chave_longa_e_aleatoria

# Use true somente quando a aplicacao estiver servida por HTTPS.
SESSION_COOKIE_SECURE=false

# Fuso usado para exibir datas no painel web.
APP_TIMEZONE=America/Sao_Paulo

# IPs de proxies reversos autorizados a definir X-Forwarded-For.
# Deixe vazio quando a API estiver exposta diretamente. Use "*" apenas em rede controlada.
TRUSTED_PROXIES=

# Dias de retencao do historico de check-ins. Use 0 para desativar a limpeza automatica.
CHECKIN_RETENTION_DAYS=90

# Limites em memoria por janela. Login usa janela de 15 minutos; check-in usa 1 minuto.
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
CHECKIN_RATE_LIMIT_MAX=30
